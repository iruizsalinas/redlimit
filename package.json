{
  "name": "redlimit",
  "version": "2.0.2",
  "description": "Redis rate limiting with fixed window, sliding window, and token bucket algorithms",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0",
    "redis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "ioredis": "5.10.1",
    "redis": "5.12.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iruizsalinas/redlimit.git"
  },
  "keywords": ["redis", "ratelimit", "backend"],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
