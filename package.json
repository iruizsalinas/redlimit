{
  "name": "redlimit",
  "version": "1.0.0",
  "description": "Redis rate limiting with fixed window, sliding window, and token bucket algorithms",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0",
    "redis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": { "optional": true },
    "redis": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "ioredis": "^5.10.1",
    "redis": "5.1.1",
    "tsup": "8.5.0",
    "typescript": "5.7.3",
    "vitest": "3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iruizsalinas/redlimit.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
